{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "crons": [
    {
      "path": "/api/opportunity-deadline-reminders",
      "schedule": "0 5 * * *"
    }
  ],
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ],
      "has": [
        {
          "type": "header",
          "key": "accept",
          "value": ".*text/html.*"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/|assets/|images/|docs/|favicon.ico|robots.txt|sitemap.xml|logo(?:-og|-social)?\\.(?:png|jpg)|firebase-messaging-sw\\.js).*)",
      "destination": "/index.html"
    }
  ]
}
